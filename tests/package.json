{
  "name": "salon-marketplace-tests",
  "version": "1.0.0",
  "description": "Test suite for Salon Marketplace Booking System",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:integration": "jest --testPathPattern=integration",
    "test:unit": "jest --testPathPattern=unit",
    "test:e2e": "playwright test",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@directus/sdk": "^18.0.0",
    "axios": "^1.6.0",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "supertest": "^6.3.3"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFilesAfterEnv": [
      "./jest.setup.js"
    ],
    "testMatch": [
      "**/tests/**/*.test.js",
      "**/tests/**/*.spec.js"
    ],
    "collectCoverageFrom": [
      "**/tests/**/*.js",
      "!**/tests/fixtures/**",
      "!**/tests/utils/**"
    ]
  }
}
